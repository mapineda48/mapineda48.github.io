---
const { profileName, role, aboutTitle, aboutDesc1, skillsTitle, skills, toolsTitle, tools, methodologiesTitle, methodologies } = Astro.props;
---

<section id="about" class="py-24 bg-white dark:bg-slate-950">
  <div class="container mx-auto px-6">
    <div class="flex flex-col md:flex-row gap-16 items-center">

      {/* Profile/Visual Side */}
      <div class="w-full md:w-1/3">
        <div class="relative">
             <div class="absolute inset-0 bg-blue-600 rounded-2xl rotate-6 opacity-20"></div>
             <div class="relative bg-slate-100 dark:bg-slate-800 rounded-2xl p-8 shadow-xl text-center">
                {/* Placeholder for Profile Image if user wants one, using initials for now */}
                <div class="w-32 h-32 mx-auto bg-slate-200 dark:bg-slate-700 rounded-full flex items-center justify-center mb-6 text-4xl font-bold text-slate-400 dark:text-slate-500">
                    MP
                </div>
                <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">{profileName}</h3>
                <p class="text-blue-600 dark:text-blue-400 font-medium mb-6">{role}</p>

                <div class="space-y-4 text-left">
                    <div>
                        <h4 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-2">{skillsTitle}</h4>
                        <div class="flex flex-wrap gap-2">
                            {skills.slice(0, 5).map((skill: string) => (
                                <span class="px-3 py-1 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-full text-xs font-medium text-slate-700 dark:text-slate-300">
                                    {skill}
                                </span>
                            ))}
                        </div>
                    </div>
                </div>
             </div>
        </div>
      </div>

      {/* Content Side */}
      <div class="w-full md:w-2/3">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-8">
            {aboutTitle}
        </h2>
        <div class="prose prose-lg dark:prose-invert text-slate-600 dark:text-slate-300 mb-10">
            <p class="leading-relaxed">
                {aboutDesc1}
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <div>
                <h4 class="text-lg font-semibold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                    <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                    {toolsTitle}
                </h4>
                <ul class="space-y-2">
                    {tools.map((tool: string) => (
                        <li class="flex items-center gap-3 text-slate-600 dark:text-slate-400">
                            <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            {tool}
                        </li>
                    ))}
                </ul>
            </div>
            <div>
                <h4 class="text-lg font-semibold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                    <span class="w-2 h-2 bg-purple-500 rounded-full"></span>
                    {methodologiesTitle}
                </h4>
                <ul class="space-y-2">
                    {methodologies.map((method: string) => (
                        <li class="flex items-center gap-3 text-slate-600 dark:text-slate-400">
                            <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            {method}
                        </li>
                    ))}
                </ul>
            </div>
        </div>
      </div>

    </div>
  </div>
</section>
